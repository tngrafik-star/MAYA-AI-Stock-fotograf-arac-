    },
    {
      "source": "/blog/stok-fotograf-anahtar-kelime-rehberi",
      "destination": "/blog/stok-fotograf-anahtar-kelime-rehberi.html"
    },
    {
      "source": "/blog/e-ticaret-urun-fotografi-seo",
      "destination": "/blog/e-ticaret-urun-fotografi-seo.html"
    },
    {
      "source": "/blog/shutterstock-satici-rehberi",
      "destination": "/blog/shutterstock-satici-rehberi.html"
    }
  ]
}
