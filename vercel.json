{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/app/(.*)",
      "destination": "/app/index.html"
    },
    {
      "source": "/auth/callback/(.*)",
      "destination": "/auth/callback/index.html"
    },
    {
      "source": "/blog/adobe-stock-fotograf-nasil-satilir",
