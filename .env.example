# Google Gemini API Key for local development
# Get your API key from Google AI Studio: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe Configuration (Test Mode)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# AI Email Auto-Responder Configuration
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=destek.mayasolutions@gmail.com
EMAIL_SMTP_PASS=your_16_character_google_app_password
EMAIL_INBOUND_SECRET=your_inbound_webhook_secret_here

# Lemon Squeezy Configuration (Test/Live Mode)
LEMON_SQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMON_SQUEEZY_STORE_ID=your_lemonsqueezy_store_id_here
LEMON_SQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret_here

