# 🔐 MAYALISTING - Environment Variables Guide
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git or share it publicly!

# ============================================
# GOOGLE GEMINI API - AI Image Analysis
# ============================================
# Get from: https://aistudio.google.com/
# 1. Go to Google AI Studio
# 2. Click "Get API key"
# 3. Create new API key or use existing
# 4. Copy the key here (starts with "AQ.")
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# SUPABASE - Database & Authentication
# ============================================
# Get from: https://supabase.com/dashboard
# 1. Create a project or open existing
# 2. Go to Settings > API
# 3. Copy "Project URL" below
# 4. Copy "anon" key (public, safe for frontend)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Get "service_role" key from Settings > API (KEEP SECRET, server-only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# STRIPE - Payment Processing (Test Mode)
# ============================================
# Get from: https://dashboard.stripe.com/test/apikeys
# 1. Go to API keys section
# 2. Copy Secret key (starts with "sk_test_")
# 3. Copy Webhook Signing Secret (from Webhook settings)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ============================================
# LEMON SQUEEZY - Alternative Payment Processor
# ============================================
# Get from: https://app.lemonsqueezy.com/settings/api
# 1. Generate API token
# 2. Copy the full JWT token below
LEMON_SQUEEZY_API_KEY=your_lemonsqueezy_api_key_here

# Get from: https://app.lemonsqueezy.com/settings/stores
# Copy your store ID
LEMON_SQUEEZY_STORE_ID=your_lemonsqueezy_store_id_here

# Get from: https://app.lemonsqueezy.com/settings/webhooks
# Copy Signing Secret from webhook configuration
LEMON_SQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret_here

# ============================================
# LEMON SQUEEZY VARIANT IDS - Pricing Tiers
# ============================================
# Get from: https://app.lemonsqueezy.com/settings/products
# Click each product and copy variant IDs for monthly/yearly
LEMON_SQUEEZY_VARIANT_STARTER=your_starter_variant_id_here
LEMON_SQUEEZY_VARIANT_STARTER_YEARLY=your_starter_yearly_variant_id_here
LEMON_SQUEEZY_VARIANT_PRO=your_pro_variant_id_here
LEMON_SQUEEZY_VARIANT_PRO_YEARLY=your_pro_yearly_variant_id_here
LEMON_SQUEEZY_VARIANT_STUDIO=your_studio_variant_id_here
LEMON_SQUEEZY_VARIANT_STUDIO_YEARLY=your_studio_yearly_variant_id_here

# ============================================
# EMAIL - SMTP Configuration (Auto-responder)
# ============================================
# Get from: https://myaccount.google.com/apppasswords (Gmail)
# 1. Enable 2-factor authentication on Google Account
# 2. Go to App Passwords
# 3. Select Mail and Device, generate password
# 4. Use that 16-character password below
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@gmail.com
EMAIL_SMTP_PASS=your_16_character_google_app_password

# Webhook secret for inbound email verification
# Generate with: openssl rand -hex 16
EMAIL_INBOUND_SECRET=your_inbound_webhook_secret_here

# ============================================
# DEPLOYMENT - Environment & Port
# ============================================
# Set to 'production' on Vercel/deployment
NODE_ENV=development
PORT=3001

# ============================================
# ⚠️  SECURITY CHECKLIST
# ============================================
# ✅ Never commit this file to git
# ✅ Never share these keys publicly
# ✅ Rotate keys if they're ever exposed
# ✅ Use different keys for dev/staging/production
# ✅ On Vercel, set variables in project settings, not vercel.json
